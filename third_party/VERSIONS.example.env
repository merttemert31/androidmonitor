# Example pinned vendor file for NetScope.
# Copy this file to VERSIONS.env and replace the dummy hashes with real commit pins.
# Do NOT leave these sample hashes in production.

BADVPN_REPO=https://github.com/shadowsocks/badvpn.git
BADVPN_COMMIT=0123456789abcdef0123456789abcdef01234567

LIBANCILLARY_REPO=https://github.com/shadowsocks/libancillary.git
LIBANCILLARY_COMMIT=89abcdef0123456789abcdef0123456789abcdef
